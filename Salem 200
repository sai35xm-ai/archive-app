<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تطبيق الأرشفة الذكي</title>
    <style>
        /* تعريف متغيرات الألوان للوضع الفاتح والداكن */
        :root {
            --bg-color: #f4f6f9;
            --text-color: #333;
            --panel-bg: #ffffff;
            --border-color: #e0e0e0;
            --accent-color: #007bff;
        }

        [data-theme="dark"] {
            --bg-color: #121212;
            --text-color: #f5f5f5;
            --panel-bg: #1e1e1e;
            --border-color: #333333;
            --accent-color: #375a7f;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            margin: 0;
            padding: 0;
            transition: all 0.3s ease;
        }

        header {
            background-color: var(--panel-bg);
            border-bottom: 1px solid var(--border-color);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .container {
            display: flex;
            height: calc(100vh - 70px);
        }

        /* القائمة الجانبية للقوالب */
        .sidebar {
            width: 250px;
            background-color: var(--panel-bg);
            border-left: 1px solid var(--border-color);
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        .sidebar h3 {
            margin-top: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .category-btn {
            background: none;
            border: none;
            color: var(--text-color);
            text-align: right;
            padding: 10px;
            font-size: 16px;
            cursor: pointer;
            border-radius: 5px;
            margin-bottom: 5px;
        }

        .category-btn:hover {
            background-color: var(--bg-color);
        }

        /* المنطقة الرئيسية للملاحظات */
        .main-content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
        }

        .search-box {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background-color: var(--panel-bg);
            color: var(--text-color);
            font-size: 16px;
            margin-bottom: 25px;
        }

        /* شبكة الملاحظات (البطاقات الملونة) */
        .notes-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
        }

        .note-card {
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            color: #333; /* لضمان وضوح النص فوق الألوان الزاهية */
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 150px;
        }

        .note-card h4 {
            margin: 0 0 10px 0;
            font-size: 18px;
        }

        .note-tags {
            margin-top: 15px;
            font-size: 12px;
            opacity: 0.8;
        }

        .tag {
            background: rgba(250, 250, 250, 0.4);
            padding: 3px 8px;
            border-radius: 15px;
            margin-left: 5px;
            display: inline-block;
        }

        /* أزرار الإضافة وثنائيات الوضع */
        .btn-round {
            background-color: var(--accent-color);
            color: white;
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            font-size: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .theme-toggle {
            background: none;
            border: 1px solid var(--border-color);
            color: var(--text-color);
            padding: 8px 15px;
            border-radius: 20px;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <header>
        <h2>تطبيق الأرشفة 🗂️</h2>
        <button class="theme-toggle" id="themeToggle">الوضع الداكن</button>
    </header>

    <div class="container">
        <aside class="sidebar">
            <h3>
                <span>القوالب</span>
                <button class="btn-round" onclick="addNewCategory()">+</button>
            </h3>
            <div id="categoriesList">
                </div>
        </aside>

        <main class="main-content">
            <input type="text" class="search-box" id="searchBox" placeholder="ابحث بالهاشتاق، التصنيف، أو الكلمات المفتاحية الدلالية...">
            
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h3>الملاحظات</h3>
                <button class="btn-round" style="width: auto; height: auto; padding: 8px 15px; border-radius: 8px; font-size: 14px;" onclick="addNewNote()">+ إضافة ملاحظة</button>
            </div>

            <div class="notes-grid" id="notesGrid">
                </div>
        </main>
    </div>

    <script>
        // التبديل بين الوضع الداكن والفاتح
        const themeToggle = document.getElementById('themeToggle');
        themeToggle.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            if (currentTheme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'light');
                themeToggle.textContent = 'الوضع الداكن';
            } else {
                document.documentElement.setAttribute('data-theme', 'dark');
                themeToggle.textContent = 'الوضع الفاتح';
            }
        });

        // دالات وهمية للتفاعل البرمجي (سيتم ربطها بـ FastAPI بالخطوة التالية)
        function addNewCategory() {
            const name = prompt("أدخل اسم القالب الجديد (مثل: ديني، ثقافي، عملي):");
            if (name) {
                const list = document.getElementById('categoriesList');
                list.innerHTML += `<button class="category-btn">📁 ${name}</button>`;
            }
        }

        function addNewNote() {
            const title = prompt("عنوان الملاحظة:");
            if (!title) return;
            const content = prompt("محتوى الملاحظة:");
            const tags = prompt("الهاشتاقات (افصل بينها بفاصلة ,):");
            const color = prompt("اختر لوناً زاهياً كخلفية (مثال: #ffe66d للأن الأصفر، #ff6b6b للأحمر، #4ecdc4 للأخضر):", "#ffe66d");

            if (title && content) {
                const grid = document.getElementById('notesGrid');
                const tagsHTML = tags ? tags.split(',').map(t => `<span class="tag">#${t.trim()}</span>`).join('') : '';
                
                grid.innerHTML += `
                    <div class="note-card" style="background-color: ${color};">
                        <div>
                            <h4>${title}</h4>
                            <p>${content}</p>
                        </div>
                        <div class="note-tags">${tagsHTML}</div>
                    </div>
                `;
            }
        }
    </script>
</body>
</html>
